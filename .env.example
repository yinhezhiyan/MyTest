# ===== Frontend (Vercel, project root: /vue) =====
VITE_API_BASE_URL=https://your-render-service.onrender.com

# ===== Backend (Render, project root: /springboot) =====
PORT=8080
DB_URL=jdbc:mysql://your-aiven-host:your-aiven-port/defaultdb?useUnicode=true&characterEncoding=utf-8&allowMultiQueries=true&useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=avnadmin
DB_PASSWORD=replace_with_real_password
JWT_SECRET=replace_with_a_32+_char_random_secret
JWT_EXPIRE_MILLIS=86400000
FILE_BASE_URL=https://your-render-service.onrender.com
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-project.vercel.app
