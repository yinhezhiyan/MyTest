<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.KnowledgePointMapper">
    <select id="selectAll" resultType="com.example.entity.KnowledgePoint">
        select * from knowledge_point
        <where>
            <if test="name != null and name != ''"> and name like concat('%', #{name}, '%')</if>
        </where>
        order by id desc
    </select>
    <select id="selectById" resultType="com.example.entity.KnowledgePoint">
        select * from knowledge_point where id = #{id}
    </select>
    <insert id="insert" parameterType="com.example.entity.KnowledgePoint" useGeneratedKeys="true" keyProperty="id">
        insert into knowledge_point(name, description, parent_id)
        values(#{name}, #{description}, #{parentId})
    </insert>
    <update id="updateById" parameterType="com.example.entity.KnowledgePoint">
        update knowledge_point set name=#{name}, description=#{description}, parent_id=#{parentId} where id=#{id}
    </update>
    <delete id="deleteById">
        delete from knowledge_point where id=#{id}
    </delete>
</mapper>
